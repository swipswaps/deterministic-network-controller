{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "PROJECT_ROOT=$(pwd) tsx server.ts",
    "setup": "chmod +x setup-system.sh fix-wifi.sh cold-start.sh sync-updates.sh && PROJECT_ROOT=$(pwd) ./setup-system.sh",
    "cold-start": "PROJECT_ROOT=$(pwd) ./cold-start.sh",
    "sync-updates": "chmod +x sync-updates.sh && PROJECT_ROOT=$(pwd) ./sync-updates.sh",
    "audit": "sqlite3 recovery_state.db \"SELECT timestamp, name, details FROM milestones ORDER BY timestamp ASC;\"",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.0.1",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "@types/express": "^4.17.21"
  }
